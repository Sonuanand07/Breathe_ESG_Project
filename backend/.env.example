# ============================================================
# BREATHE ESG - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and configure for your environment
# IMPORTANT: Never commit .env file to version control
# ============================================================

# ==================== DJANGO ====================
# Application debug mode
# Set to False in production
DEBUG=True

# Secret key for Django
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# MUST change in production!
SECRET_KEY=django-insecure-local-dev-secret-change-in-production

# Allowed hosts for CORS requests
ALLOWED_HOSTS=localhost,127.0.0.1,127.0.0.1:3000,localhost:3000

# ==================== DATABASE ====================
# Choose ONE database backend:

# Option 1: SQLite (Local Development - RECOMMENDED FOR QUICK START)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=backend/db.sqlite3

# Option 2: PostgreSQL (Production - Uncomment below and set values)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=breathe_esg
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# ==================== FRONTEND ====================
# URL where React frontend is running
FRONTEND_URL=http://localhost:3000

# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Trusted origins for CSRF (comma-separated)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ==================== SECURITY ====================
# Force HTTPS in production
SECURE_SSL_REDIRECT=False

# Secure cookies in production
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# HSTS (HTTP Strict Transport Security) - set only in production
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False

# ==================== CELERY & REDIS ====================
# Optional: Celery for background tasks
# Requires Redis to be running: redis-server

# Redis broker for Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# Redis backend for Celery results
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Celery settings
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# ==================== EMAIL (OPTIONAL) ====================
# For sending notifications and password reset emails
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@example.com

# ==================== AWS S3 (OPTIONAL) ====================
# For cloud file storage (alternative to local file storage)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=your-bucket.s3.amazonaws.com

# ==================== LOGGING ====================
# Logging level
LOG_LEVEL=INFO

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://key@sentry.io/project-id

# ==================== API DOCUMENTATION ====================
# DRF Spectacular (OpenAPI/Swagger) settings
API_TITLE=Breathe ESG Data Ingestion API
API_VERSION=1.0.0
API_DESCRIPTION=API for ingesting and reviewing emissions data

# ==================== THIRD-PARTY INTEGRATIONS (OPTIONAL) ====================
# SendGrid for email
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# OAuth providers
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxxx

# GitHub OAuth
# GITHUB_CLIENT_ID=xxxxx
# GITHUB_CLIENT_SECRET=xxxxx

# ==================== PRODUCTION OVERRIDES ====================
# When deploying to production, ensure:
# 1. SECRET_KEY is changed to a secure random value
# 2. DEBUG is set to False
# 3. ALLOWED_HOSTS includes your domain
# 4. Database is PostgreSQL on a managed service
# 5. All credentials are in environment variables, not here
# 6. HTTPS is enforced
# 7. Backups are configured

